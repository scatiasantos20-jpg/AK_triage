  "action_rules": {
    "priority_order": [
      "NO_REPLY",
      "CREATE_DRAFT",
      "REVIEW_MANUALLY"
    ],
    "never_create_draft_if": [
      "sender_in:no_reply_senders",
      "sender_in:newsletter_senders",
      "sender_in:cold_outreach_senders",
      "sender_in:suspicious_senders",
      "domain_in:no_reply_domains",
      "subject_matches:auto_notification",
      "subject_matches:calendar_rsvp_no_reply",
      "subject_matches:newsletter",
      "body_matches:newsletter",
      "body_matches:cold_outreach",
      "body_matches:suspicious"
    ],
    "create_draft_if": [
      "sender_in:trusted_human_senders",
      "domain_in:trusted_human_domains",
      "subject_matches:create_draft_subject",
      "body_matches:create_draft_body"
    ],
    "review_manually_if": [
      "subject_matches:review_manually_subject",
      "body_matches:review_manually_body"
    ],
    "default_action": "REVIEW_MANUALLY"
  }
}
